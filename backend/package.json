{
  "name": "telkantin-backend",
  "version": "1.0.0",
  "description": "TELKANTIN - Sistem Kantin Kampus (Microservices Backend)",
  "private": true,
  "workspaces": [
    "user-service"
  ],
  "homepage": "https://github.com/evxz0/TELKANTIN#readme",
  "bugs": {
    "url": "https://github.com/evxz0/TELKANTIN/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/evxz0/TELKANTIN.git"
  },
  "scripts": {
    "dev:user": "cd user-service && npm run dev",
    "start:user": "cd user-service && npm start",
    "test:user": "cd user-service && npm test",
    "install:user": "cd user-service && npm install",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  }
}
